{
    "name": "@mr.dj2u/mercury-ui",
    "version": "0.2.1",
    "description": "Standalone Mercury UI workflows extracted from Time2Pay",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "assets",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@mr.dj2u/mercury": "0.1.0",
        "@react-native-picker/picker": "^2.11.4"
    },
    "peerDependencies": {
        "react": ">=19",
        "react-native": ">=0.83"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/DavidJGrimsley/mercury-bank-sdk"
    },
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    }
}
